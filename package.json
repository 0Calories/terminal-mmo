{
	"name": "terminal-mmo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun run packages/client/src/index.ts",
		"dev:client": "bun run packages/client/src/index.ts",
		"dev:server": "bun run packages/server/src/index.ts",
		"test": "bun test",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"ci": "biome ci ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/node": "^26.0.0",
		"bun-types": "^1.3.14",
		"typescript": "^5.6.0"
	}
}
