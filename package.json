{
	"name": "terminal-mmo-workspace",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"start": "bun run packages/server/src/index.ts",
		"dev": "bun run packages/client/src/index.ts",
		"dev:client": "bun run packages/client/src/index.ts",
		"dev:server": "bun run packages/server/src/index.ts",
		"build:cli": "bun run packages/cli/build.ts",
		"zone": "bun run packages/zone-tools/bin/zone.ts",
		"zones:check": "bun run packages/zone-tools/bin/zone.ts check",
		"zones:preview": "bun run packages/zone-tools/bin/zone.ts preview",
		"zones:play": "bun run packages/zone-tools/bin/zone.ts play",
		"zones:edit": "bun run packages/zone-tools/bin/zone.ts edit",
		"test": "bun test",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"ci": "biome ci . && bun run typecheck && bun test && bun run zones:check"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/node": "^26.0.0",
		"bun-types": "^1.3.14",
		"typescript": "^5.6.0"
	}
}
